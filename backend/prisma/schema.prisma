generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model credit_usages {
  id           BigInt    @id @default(autoincrement())
  user_id      BigInt
  feature_code String    @db.VarChar(100)
  credits_used Int
  description  String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model features {
  id               BigInt             @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  name             String             @db.VarChar(100)
  description      String?
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  package_features package_features[]
  user_features    user_features[]
}

model package_features {
  package_id BigInt
  feature_id BigInt
  features   features @relation(fields: [feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  packages   packages @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([package_id, feature_id])
}

model packages {
  id               BigInt             @id @default(autoincrement())
  name             String             @db.VarChar(100)
  description      String?
  price            Decimal            @db.Decimal(12, 2)
  credits          Int
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  package_features package_features[]
  transactions     transactions[]
}

model transactions {
  id               BigInt          @id @default(autoincrement())
  transaction_code String          @unique @db.VarChar(100)
  user_id          BigInt
  package_id       BigInt?
  amount           Decimal         @db.Decimal(12, 2)
  credits          Int
  status           String          @default("PENDING") @db.VarChar(50)
  payment_method   String?         @db.VarChar(50)
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  updated_at       DateTime?       @default(now()) @db.Timestamp(6)
  packages         packages?       @relation(fields: [package_id], references: [id], onUpdate: NoAction)
  users            users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_features    user_features[]
}

model user_credits {
  id         BigInt    @id @default(autoincrement())
  user_id    BigInt    @unique
  balance    Int       @default(0)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user_features {
  id                    BigInt        @id @default(autoincrement())
  user_id               BigInt
  feature_id            BigInt
  source_transaction_id BigInt?
  unlocked_at           DateTime?     @default(now()) @db.Timestamp(6)
  features              features      @relation(fields: [feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions          transactions? @relation(fields: [source_transaction_id], references: [id], onUpdate: NoAction)
  users                 users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, feature_id])
}

model users {
  id            BigInt          @id @default(autoincrement())
  name          String          @db.VarChar(100)
  email         String          @unique @db.VarChar(150)
  password_hash String          @db.VarChar(255)
  role          String          @default("USER") @db.VarChar(50)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  credit_usages credit_usages[]
  transactions  transactions[]
  user_credits  user_credits?
  user_features user_features[]
}
